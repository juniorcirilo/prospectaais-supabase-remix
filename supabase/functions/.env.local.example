# Exemplo de Configuração .env.local para Desenvolvimento

# Copie este arquivo para supabase/functions/.env.local
# NÃO commite este arquivo! Adicione ao .gitignore

# ────────────────────────────────────────────────────────────
# ESCOLHA UMA OPÇÃO ABAIXO (comente as outras)
# O sistema usa a primeira chave configurada encontrada
# ────────────────────────────────────────────────────────────

# 1. GROQ (Recomendado - rápido + barato)
# https://console.groq.com
# GROQ_API_KEY=gsk_your_key_here

# 2. GOOGLE GEMINI (Simples + Grátis)
# https://aistudio.google.com/apikey
# GOOGLE_GEMINI_API_KEY=AIzaSy...

# 3. LOVABLE (Gateway com múltiplos modelos)
# https://www.lovable.dev
# LOVABLE_API_KEY=...

# 4. OPENAI (ChatGPT)
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# 5. ANTHROPIC CLAUDE (Melhor reasoning)
# https://console.anthropic.com/keys
# ANTHROPIC_API_KEY=sk-ant-...

# ────────────────────────────────────────────────────────────
# EXEMPLO: Para usar Groq
# ────────────────────────────────────────────────────────────
# Descomente a linha abaixo e adicione sua chave Groq
# GROQ_API_KEY=gsk_your_key_here
